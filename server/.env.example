# ShopMCP API — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Origins allowed to call this API (comma-separated).
# Local: add http://localhost:8080 or wherever you serve the frontend.
# Production: your GitHub Pages URL.
ALLOWED_ORIGIN=http://localhost:8080,https://cjmuir.github.io/WebMCP-Demo-Retail

# ── PingOne (runtime values, not secrets) ─────────────────────────────────────
PINGONE_ENVIRONMENT_ID=

# Optional: the `aud` claim value the RS expects.
# Leave blank if your PingOne AS does not set a specific audience on the AT.
PINGONE_API_AUDIENCE=

# ── PingOne Authorize — Worker Application (SECRET) ───────────────────────────
# These are the credentials of a *Worker* (M2M) application in PingOne —
# NOT the same application as the browser PKCE client.
# The worker app is granted access to call the Decision Endpoint API.

AZ_CLIENT_ID=
AZ_CLIENT_SECRET=

# The UUID of your PingOne Authorize Decision Endpoint.
# Found at: Authorize → Decision Endpoints → <your endpoint> → ID
AZ_DECISION_ENDPOINT_ID=

# ── Optional ──────────────────────────────────────────────────────────────────
# Leave AZ_DECISION_ENDPOINT_ID blank to run without Authorize (auto-PERMIT all checkouts).
# Useful for local dev when you want to test the API without a full PingOne AZ setup.
